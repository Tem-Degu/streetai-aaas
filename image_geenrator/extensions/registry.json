{
  "extensions": [
    {
      "name": "aimlapi",
      "type": "api",
      "description": "AI image generation API using the alibaba/z-image-turbo model",
      "endpoint": "https://api.aimlapi.com",
      "auth": {
        "type": "bearer",
        "apiKey": "e035570db463841cc2599f2d1e27ae07"
      },
      "operations": [
        {
          "name": "generate_image",
          "description": "Generate an AI image from a text prompt using alibaba/z-image-turbo",
          "method": "POST",
          "path": "/v1/images/generations",
          "body": {
            "model": "alibaba/z-image-turbo",
            "prompt": "...",
            "image_size": "landscape_4_3",
            "output_format": "png",
            "num_images": 1,
            "enable_prompt_expansion": true,
            "enable_safety_checker": true,
            "acceleration": "regular"
          },
          "returns": "JSON with data array containing image URLs",
          "output_type": "json"
        }
      ]
    }
  ]
}
